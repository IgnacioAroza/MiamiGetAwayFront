# URL base de la API backend
# En desarrollo: http://localhost:3001/api
# En producción: URL del servidor desplegado
VITE_API_URL=

# Número de WhatsApp para contacto (formato internacional sin + ni espacios)
# Ejemplo: 14155552671
VITE_WHATSAPP_NUMBER=

# Número de WhatsApp alternativo para Argentina
# Ejemplo: 5491155552671
VITE_ARGENTINA_WHATSAPP_NUMBER=

# Credenciales de EmailJS (https://www.emailjs.com)
# Service ID: se obtiene en Email Services del dashboard
VITE_EMAILJS_SERVICE_ID=
# Template ID: se obtiene en Email Templates del dashboard
VITE_EMAILJS_TEMPLATE_ID=
# Public Key: se obtiene en Account > API Keys
VITE_EMAILJS_PUBLIC_KEY=
